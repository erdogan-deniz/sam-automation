# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.mypy_cache/
.venv/

# ── Secrets / Local Config ────────────────────────────────────────────────────
.env
config.yaml

# ── Runtime State ─────────────────────────────────────────────────────────────
data/*
!data/.gitkeep
logs/*
!logs/.gitkeep

# ── SAM Binaries (auto-downloaded on first run) ───────────────────────────────
SAM/*
!SAM/.gitkeep

# ── Tooling ───────────────────────────────────────────────────────────────────
.cache/
*.orig
Options
