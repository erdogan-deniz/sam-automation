# ── Default: normalize line endings to LF ────────────────────────────────────
* text=auto eol=lf

# ── Source Code ───────────────────────────────────────────────────────────────
*.py   text eol=lf diff=python
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# ── Docs / Config ─────────────────────────────────────────────────────────────
*.md   text eol=lf
*.txt  text eol=lf
*.cfg  text eol=lf
*.ini  text eol=lf

# ── Windows Scripts (must use CRLF) ──────────────────────────────────────────
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# ── Binaries (no line-ending conversion, no diff) ────────────────────────────
*.exe  binary
*.dll  binary
*.zip  binary
*.png  binary
*.ico  binary
